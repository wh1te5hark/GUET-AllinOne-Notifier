# 复制为 .env 后按需修改

# development | staging | production
GUET_ENV=development

# HTTP 绑定（__main__ 启动时使用）
GUET_HOST=127.0.0.1
GUET_PORT=8000

# 数据库连接（默认会落到 backend/.data/app.db；也可切换 MySQL）
# GUET_DATABASE_URL=sqlite:///./.data/app.db

# 学校 CAS 登录入口
GUET_CAS_BASE_URL=https://cas.guet.edu.cn

# 后续阶段：加密凭据主密钥（示例占位）
# GUET_SECRET_KEY=
